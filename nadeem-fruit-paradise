    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @media(max-width:768px) {
      nav ul { display: none; }
      .hero-stats { gap: 24px; }
      section { padding: 70px 6vw; }
    }
  </style>
</head>
