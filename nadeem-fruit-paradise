<script>
  const fruits = ['🍓','🥭','🍉','🍍','🍇','🍒','🫐','🥝','🍑','🍈','🍊','🍋','🍌','🍏','🍎','🍐'];
  const floaters = document.getElementById('floaters');
  fruits.forEach((f, i) => {
    const el = document.createElement('span');
    el.className = 'floater';
    el.textContent = f;
    el.style.left = (5 + (i / fruits.length) * 90) + '%';
    el.style.animationDuration = (12 + Math.random() * 14) + 's';
    el.style.animationDelay = (Math.random() * 12) + 's';
    floaters.appendChild(el);
  });

  const fruitData = [
    { e:'🥭', name:'Alphonso Mango',      origin:'Ratnagiri, Maharashtra', tag:'SEASONAL STAR' },
    { e:'🍉', name:'Seedless Watermelon', origin:'Local Farms, Bengal',    tag:'SUMMER SPECIAL' },
    { e:'🍓', name:'Fresh Strawberries',  origin:'Mahabaleshwar',          tag:'IMPORTED' },
    { e:'🍍', name:'Sweet Pineapple',     origin:'West Bengal',            tag:'DAILY FRESH' },
    { e:'🍇', name:'Seedless Grapes',     origin:'Nashik, Maharashtra',    tag:'PREMIUM' },
    { e:'🫐', name:'Blueberries',         origin:'Imported',               tag:'EXOTIC' },
    { e:'🥝', name:'Green Kiwi',          origin:'New Zealand',            tag:'IMPORTED' },
    { e:'🍒', name:'Red Cherries',        origin:'Himachal Pradesh',       tag:'LIMITED' },
  ];
  const grid = document.getElementById('fruitGrid');
  const gradients = [
    'linear-gradient(135deg,#fff3e0,#ffe0b2)',
    'linear-gradient(135deg,#e8f5e9,#c8e6c9)',
    'linear-gradient(135deg,#fce4ec,#f8bbd9)',
    'linear-gradient(135deg,#fff9c4,#fff176)',
    'linear-gradient(135deg,#e3f2fd,#bbdefb)',
    'linear-gradient(135deg,#f3e5f5,#e1bee7)',
    'linear-gradient(135deg,#e0f7fa,#b2ebf2)',
    'linear-gradient(135deg,#fbe9e7,#ffccbc)',
  ];
  fruitData.forEach((f, i) => {
    grid.innerHTML += `
      <div class="fruit-card reveal">
        <div class="fruit-emoji-box" style="background:${gradients[i%gradients.length]}">
          <span style="filter:drop-shadow(0 4px 8px rgba(0,0,0,.15))">${f.e}</span>
        </div>
        <div class="fruit-card-body">
          <div class="fruit-name">${f.name}</div>
          <div class="fruit-origin">${f.origin}</div>
          <span class="fruit-tag">${f.tag}</span>
        </div>
      </div>`;
  });

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }});
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  setTimeout(() => document.querySelector('#hero .reveal')?.classList.add('visible'), 100);
</script>
